#!/usr/bin/env bash
# Usage: source ./configs/env.sh
# Sets environment variables for the pipeline in the current shell session.

# SonarQube
export SONAR_SCANNER="/path/to/sonar-scanner"
export SONAR_HOST_URL="http://localhost:9000"
export SONAR_TOKEN="your_sonar_token"

# LLM provider (choose one)
# export LLM_PROVIDER="openai"
# export OPENAI_API_KEY="your_openai_key"
# export OPENAI_MODEL="gpt-4o-mini"

# export LLM_PROVIDER="gemini"
# export GEMINI_API_KEY="your_gemini_key"
# export GEMINI_MODEL="gemini-1.5-flash"

# export LLM_PROVIDER="ollama"
# export OLLAMA_HOST="http://localhost:11434"
# export OLLAMA_MODEL="qwen2.5-coder:7b"

# LLM sampling
export LLM_SAMPLE_SIZE="400"
export LLM_SAMPLE_SEED="42"
export LLM_SAMPLE_STRATEGY="stratified"
export LLM_SAMPLE_MIN_PER_REPO="20"
export LLM_SAMPLE_MANIFEST="data/results/llm_sample_manifest.csv"
export LLM_RESUME="true"
export LLM_WRITE_EVERY="25"
export LLM_SORT_OUTPUT="true"

# Optional risk-stratified controls (used only if LLM_SAMPLE_STRATEGY=risk_stratified)
# export LLM_SAMPLE_RISK_FRACTION="0.35"
# export LLM_SAMPLE_RISK_CHURN_QUANTILE="0.75"

# Optional validation
export VALIDATE_OUTPUTS="false"
