# Usage: copy to configs/env.ps1 and edit values
# Sets environment variables for the pipeline in the current PowerShell session.

# SonarQube
$Env:SONAR_SCANNER = "C:\sonar-scanner\bin\sonar-scanner.bat"
$Env:SONAR_HOST_URL = "http://localhost:9000"
$Env:SONAR_TOKEN = "your_sonar_token"

# LLM provider (choose one)
# $Env:LLM_PROVIDER = "openai"
# $Env:OPENAI_API_KEY = "your_openai_key"
# $Env:OPENAI_MODEL = "gpt-4o-mini"

# $Env:LLM_PROVIDER = "gemini"
# $Env:GEMINI_API_KEY = "your_gemini_key"
# $Env:GEMINI_MODEL = "gemini-1.5-flash"

# $Env:LLM_PROVIDER = "ollama"
# $Env:OLLAMA_HOST = "http://localhost:11434"
# $Env:OLLAMA_MODEL = "qwen2.5-coder:7b"

# LLM sampling
$Env:LLM_SAMPLE_SIZE = "400"
$Env:LLM_SAMPLE_SEED = "42"
$Env:LLM_SAMPLE_STRATEGY = "stratified"
$Env:LLM_SAMPLE_MIN_PER_REPO = "20"
$Env:LLM_SAMPLE_MANIFEST = "data/results/llm_sample_manifest.csv"
$Env:LLM_RESUME = "true"
$Env:LLM_WRITE_EVERY = "25"
$Env:LLM_SORT_OUTPUT = "true"

# Optional risk-stratified controls (used only if LLM_SAMPLE_STRATEGY=risk_stratified)
# $Env:LLM_SAMPLE_RISK_FRACTION = "0.35"
# $Env:LLM_SAMPLE_RISK_CHURN_QUANTILE = "0.75"

# Optional validation
$Env:VALIDATE_OUTPUTS = "false"

Write-Host "Environment variables set for this session."
